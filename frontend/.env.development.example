# Use same-origin /api in the browser and let Vite proxy to backend.
VITE_API_BASE_URL=/api

# Local backend target used by Vite dev proxy.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8002

# Optional: Google Geocoding API key for more accurate street-number geocoding.
# Restrict this key by HTTP referrer to your dev/prod domains.
VITE_GOOGLE_MAPS_API_KEY=
