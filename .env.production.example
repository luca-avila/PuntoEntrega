# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db

# Backend
# For local backend-only runs (outside docker compose), set a direct DB URL:
# DATABASE_URL=sqlite+aiosqlite:///./test.db
SECRET_KEY=changeme
ENVIRONMENT=production
LOG_LEVEL=INFO
LOG_REQUESTS=true
# Must be JSON array syntax (string)
CORS_ORIGINS=["http://your-frontend.com", "http://www.your-frontend.com"]
FRONTEND_URL=http://your-frontend.com
RESEND_API_KEY=
EMAIL_FROM=Project <onboarding@resend.dev>