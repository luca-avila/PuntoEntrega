# PostgreSQL / backend runtime
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=auth
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

SECRET_KEY=change-me-generate-a-strong-secret
ENVIRONMENT=production
LOG_LEVEL=INFO
LOG_REQUESTS=true

CORS_ORIGINS='["https://puntoentrega.example", "https://www.puntoentrega.example"]'
FRONTEND_URL=https://puntoentrega.example
RESEND_API_KEY=
EMAIL_FROM='PuntoEntrega <no-reply@puntoentrega.example>'

# Build / registry
GHCR_OWNER=your-github-user
BACKEND_IMAGE_NAME=puntoentrega-backend
FRONTEND_IMAGE_NAME=puntoentrega-frontend
BACKEND_IMAGE_TAG=1.0.0
FRONTEND_IMAGE_TAG=1.0.0
BACKEND_IMAGE_REF=ghcr.io/${GHCR_OWNER}/${BACKEND_IMAGE_NAME}:${BACKEND_IMAGE_TAG}
FRONTEND_IMAGE_REF=ghcr.io/${GHCR_OWNER}/${FRONTEND_IMAGE_NAME}:${FRONTEND_IMAGE_TAG}

# Frontend build-time public variables
VITE_API_BASE_URL=/api
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8002
VITE_GOOGLE_MAPS_API_KEY=
