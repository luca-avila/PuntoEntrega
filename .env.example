# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=auth

# Backend
# For local backend-only runs (outside docker compose), set a direct DB URL:
# DATABASE_URL=sqlite+aiosqlite:///./test.db
SECRET_KEY=changeme
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_REQUESTS=true
CORS_ORIGINS=["https://auth.example.com"]
FRONTEND_URL=https://auth.example.com
RESEND_API_KEY=
EMAIL_FROM=Auth Module <onboarding@resend.dev>
VERIFY_PATH=/verify-email
RESET_PASSWORD_PATH=/reset-password
DELIVERY_SUMMARY_RECIPIENTS=logistica@example.com,facturacion@example.com

# Password validation policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true
